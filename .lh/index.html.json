            "name": "Commit-0",
            "content": "<!doctype html>\n<html lang=\"ko\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>로또 추첨기</title>\n    <style>\n      :root {\n        --bg1: #0f172a;\n        --bg2: #1e293b;\n        --card: rgba(255, 255, 255, 0.1);\n        --line: rgba(255, 255, 255, 0.15);\n        --text: #f8fafc;\n        --muted: #cbd5e1;\n        --accent: #22c55e;\n        --accent2: #38bdf8;\n        --danger: #ef4444;\n        --shadow: 0 20px 40px rgba(0, 0, 0, 0.25);\n      }\n\n      * {\n        box-sizing: border-box;\n      }\n\n      body {\n        margin: 0;\n        font-family:\n          'Pretendard', 'Apple SD Gothic Neo', 'Noto Sans KR', sans-serif;\n        color: var(--text);\n        background:\n          radial-gradient(\n            circle at top left,\n            rgba(56, 189, 248, 0.18),\n            transparent 28%\n          ),\n          radial-gradient(\n            circle at top right,\n            rgba(34, 197, 94, 0.16),\n            transparent 24%\n          ),\n          linear-gradient(135deg, var(--bg1), var(--bg2));\n        min-height: 100vh;\n        padding: 24px;\n      }\n\n      .wrap {\n        max-width: 1100px;\n        margin: 0 auto;\n      }\n\n      .hero {\n        text-align: center;\n        margin-bottom: 22px;\n      }\n\n      .hero h1 {\n        margin: 0 0 10px;\n        font-size: clamp(2rem, 4vw, 3.2rem);\n        letter-spacing: -0.03em;\n      }\n\n      .hero p {\n        margin: 0;\n        color: var(--muted);\n        line-height: 1.7;\n      }\n\n      .grid {\n        display: grid;\n        grid-template-columns: 1.3fr 0.7fr;\n        gap: 20px;\n      }\n\n      .panel {\n        background: var(--card);\n        border: 1px solid var(--line);\n        border-radius: 24px;\n        box-shadow: var(--shadow);\n        backdrop-filter: blur(14px);\n        -webkit-backdrop-filter: blur(14px);\n        padding: 22px;\n      }\n\n      .section-title {\n        display: flex;\n        align-items: center;\n        justify-content: space-between;\n        gap: 12px;\n        margin-bottom: 18px;\n      }\n\n      .section-title h2 {\n        margin: 0;\n        font-size: 1.2rem;\n      }\n\n      .badge {\n        padding: 6px 10px;\n        border-radius: 999px;\n        background: rgba(255, 255, 255, 0.1);\n        border: 1px solid rgba(255, 255, 255, 0.14);\n        color: var(--muted);\n        font-size: 0.85rem;\n      }\n\n      .machine {\n        padding: 28px 20px;\n        border-radius: 24px;\n        background: linear-gradient(\n          180deg,\n          rgba(255, 255, 255, 0.1),\n          rgba(255, 255, 255, 0.05)\n        );\n        border: 1px solid rgba(255, 255, 255, 0.12);\n      }\n\n      .balls {\n        display: flex;\n        flex-wrap: wrap;\n        justify-content: center;\n        gap: 14px;\n        min-height: 104px;\n        align-items: center;\n      }\n\n      .ball {\n        width: 68px;\n        height: 68px;\n        border-radius: 50%;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-weight: 800;\n        font-size: 1.4rem;\n        color: white;\n        box-shadow:\n          inset 0 -8px 14px rgba(0, 0, 0, 0.16),\n          0 10px 18px rgba(0, 0, 0, 0.18);\n        transform: scale(0.7);\n        opacity: 0;\n        transition: 0.35s ease;\n        user-select: none;\n      }\n\n      .ball.show {\n        transform: scale(1);\n        opacity: 1;\n      }\n\n      .ball.yellow {\n        background: linear-gradient(135deg, #fbbf24, #f59e0b);\n      }\n      .ball.blue {\n        background: linear-gradient(135deg, #60a5fa, #2563eb);\n      }\n      .ball.red {\n        background: linear-gradient(135deg, #fb7185, #e11d48);\n      }\n      .ball.gray {\n        background: linear-gradient(135deg, #94a3b8, #64748b);\n      }\n      .ball.green {\n        background: linear-gradient(135deg, #4ade80, #16a34a);\n      }\n      .ball.bonus {\n        outline: 4px solid rgba(255, 255, 255, 0.22);\n      }\n\n      .plus {\n        font-size: 1.8rem;\n        font-weight: 800;\n        color: #e2e8f0;\n        opacity: 0.8;\n        align-self: center;\n        display: none;\n      }\n\n      .plus.show {\n        display: block;\n      }\n\n      .controls {\n        display: flex;\n        flex-wrap: wrap;\n        gap: 12px;\n        justify-content: center;\n        margin-top: 24px;\n      }\n\n      button {\n        border: 0;\n        cursor: pointer;\n        border-radius: 14px;\n        padding: 14px 18px;\n        font-size: 1rem;\n        font-weight: 700;\n        transition:\n          transform 0.15s ease,\n          opacity 0.2s ease,\n          box-shadow 0.2s ease;\n      }\n\n      button:hover {\n        transform: translateY(-1px);\n      }\n      button:active {\n        transform: translateY(1px);\n      }\n      button:disabled {\n        cursor: not-allowed;\n        opacity: 0.55;\n      }\n\n      .primary {\n        background: linear-gradient(135deg, var(--accent), #16a34a);\n        color: white;\n        box-shadow: 0 10px 24px rgba(34, 197, 94, 0.25);\n      }\n\n      .secondary {\n        background: linear-gradient(135deg, var(--accent2), #2563eb);\n        color: white;\n        box-shadow: 0 10px 24px rgba(56, 189, 248, 0.2);\n      }\n\n      .ghost {\n        background: rgba(255, 255, 255, 0.08);\n        color: white;\n        border: 1px solid rgba(255, 255, 255, 0.12);\n      }\n\n      .danger {\n        background: rgba(239, 68, 68, 0.15);\n        color: #fecaca;\n        border: 1px solid rgba(239, 68, 68, 0.28);\n      }\n\n      .status {\n        text-align: center;\n        margin-top: 18px;\n        color: var(--muted);\n        min-height: 24px;\n        font-size: 0.98rem;\n      }\n\n      .stats {\n        display: grid;\n        grid-template-columns: repeat(2, 1fr);\n        gap: 12px;\n        margin-top: 18px;\n      }\n\n      .stat {\n        background: rgba(255, 255, 255, 0.06);\n        border: 1px solid rgba(255, 255, 255, 0.1);\n        border-radius: 18px;\n        padding: 16px;\n      }\n\n      .stat .label {\n        color: var(--muted);\n        font-size: 0.88rem;\n        margin-bottom: 8px;\n      }\n\n      .stat .value {\n        font-size: 1.4rem;\n        font-weight: 800;\n      }\n\n      .history-list {\n        display: grid;\n        gap: 10px;\n        max-height: 460px;\n        overflow: auto;\n        padding-right: 4px;\n      }\n\n      .history-item {\n        padding: 14px;\n        border-radius: 16px;\n        background: rgba(255, 255, 255, 0.06);\n        border: 1px solid rgba(255, 255, 255, 0.1);\n      }\n\n      .history-head {\n        display: flex;\n        justify-content: space-between;\n        gap: 10px;\n        margin-bottom: 10px;\n        color: var(--muted);\n        font-size: 0.9rem;\n      }\n\n      .mini-balls {\n        display: flex;\n        flex-wrap: wrap;\n        gap: 8px;\n        align-items: center;\n      }\n\n      .mini-ball {\n        width: 32px;\n        height: 32px;\n        border-radius: 50%;\n        display: inline-flex;\n        align-items: center;\n        justify-content: center;\n        font-size: 0.9rem;\n        font-weight: 800;\n        color: white;\n        box-shadow: inset 0 -5px 8px rgba(0, 0, 0, 0.16);\n      }\n\n      .empty {\n        color: var(--muted);\n        text-align: center;\n        padding: 28px 10px;\n        border: 1px dashed rgba(255, 255, 255, 0.18);\n        border-radius: 16px;\n      }\n\n      .footer {\n        text-align: center;\n        color: var(--muted);\n        margin-top: 18px;\n        font-size: 0.92rem;\n      }\n\n      @media (max-width: 920px) {\n        .grid {\n          grid-template-columns: 1fr;\n        }\n      }\n\n      @media (max-width: 600px) {\n        body {\n          padding: 16px;\n        }\n        .panel {\n          padding: 18px;\n        }\n        .ball {\n          width: 56px;\n          height: 56px;\n          font-size: 1.18rem;\n        }\n        .plus {\n          font-size: 1.5rem;\n        }\n        .stats {\n          grid-template-columns: 1fr;\n        }\n      }\n    </style>\n  </head>\n  <body>\n    <div class=\"wrap\">\n      <div class=\"hero\">\n        <h1>🎱 로또 추첨 사이트</h1>\n        <p>\n          1부터 45까지 중복 없이 6개 번호와 보너스 번호 1개를 추첨합니다.<br />추첨\n          기록은 브라우저에 자동 저장됩니다.\n        </p>\n      </div>\n\n      <div class=\"grid\">\n        <section class=\"panel\">\n          <div class=\"section-title\">\n            <h2>🎲 추첨기</h2>\n            <span class=\"badge\" id=\"roundLabel\">준비 완료</span>\n          </div>\n\n          <div class=\"machine\">\n            <div class=\"balls\" id=\"balls\"></div>\n            <div class=\"status\" id=\"status\">추첨 시작 버튼을 눌러주세요.</div>\n            <div class=\"controls\">\n              <button class=\"primary\" id=\"drawBtn\">추첨 시작</button>\n              <button class=\"secondary\" id=\"quickBtn\">즉시 추첨</button>\n              <button class=\"ghost\" id=\"copyBtn\">번호 복사</button>\n              <button class=\"danger\" id=\"resetBtn\">기록 초기화</button>\n            </div>\n          </div>\n\n          <div class=\"stats\">\n            <div class=\"stat\">\n              <div class=\"label\">총 추첨 횟수</div>\n              <div class=\"value\" id=\"totalDraws\">0회</div>\n            </div>\n            <div class=\"stat\">\n              <div class=\"label\">최근 추첨 번호</div>\n              <div class=\"value\" id=\"latestSummary\">-</div>\n            </div>\n          </div>\n        </section>\n\n        <aside class=\"panel\">\n          <div class=\"section-title\">\n            <h2>🧾 추첨 기록</h2>\n            <span class=\"badge\">최근순 저장</span>\n          </div>\n          <div class=\"history-list\" id=\"historyList\"></div>\n        </aside>\n      </div>\n\n      <div class=\"footer\">\n        ✨ 단일 HTML 파일로 동작하며 별도 설치가 필요 없습니다.\n      </div>\n    </div>\n\n    <script>\n      const STORAGE_KEY = 'lotto_draw_history_v1'\n      const ballsEl = document.getElementById('balls')\n      const statusEl = document.getElementById('status')\n      const historyListEl = document.getElementById('historyList')\n      const totalDrawsEl = document.getElementById('totalDraws')\n      const latestSummaryEl = document.getElementById('latestSummary')\n      const roundLabelEl = document.getElementById('roundLabel')\n      const drawBtn = document.getElementById('drawBtn')\n      const quickBtn = document.getElementById('quickBtn')\n      const copyBtn = document.getElementById('copyBtn')\n      const resetBtn = document.getElementById('resetBtn')\n\n      let history = loadHistory()\n      let latestDraw = history[0] || null\n      let drawing = false\n\n      function loadHistory() {\n        try {\n          return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []\n        } catch {\n          return []\n        }\n      }\n\n      function saveHistory() {\n        localStorage.setItem(STORAGE_KEY, JSON.stringify(history))\n      }\n\n      function pickNumbers() {\n        const numbers = Array.from({ length: 45 }, (_, i) => i + 1)\n        for (let i = numbers.length - 1; i > 0; i--) {\n          const j = Math.floor(Math.random() * (i + 1))\n          ;[numbers[i], numbers[j]] = [numbers[j], numbers[i]]\n        }\n        const selected = numbers.slice(0, 7)\n        const main = selected.slice(0, 6).sort((a, b) => a - b)\n        const bonus = selected[6]\n        return { main, bonus }\n      }\n\n      function getColorClass(num) {\n        if (num <= 10) return 'yellow'\n        if (num <= 20) return 'blue'\n        if (num <= 30) return 'red'\n        if (num <= 40) return 'gray'\n        return 'green'\n      }\n\n      function createBall(num, isBonus = false, mini = false) {\n        const el = document.createElement('div')\n        el.className =\n          `${mini ? 'mini-ball' : 'ball'} ${getColorClass(num)} ${isBonus ? 'bonus' : ''}`.trim()\n        el.textContent = num\n        return el\n      }\n\n      function renderCurrent(draw) {\n        ballsEl.innerHTML = ''\n        if (!draw) return\n\n        draw.main.forEach((num, idx) => {\n          const ball = createBall(num, false, false)\n          ballsEl.appendChild(ball)\n          requestAnimationFrame(() => {\n            setTimeout(() => ball.classList.add('show'), idx * 70)\n          })\n        })\n\n        const plus = document.createElement('div')\n        plus.className = 'plus'\n        plus.textContent = '+'\n        ballsEl.appendChild(plus)\n\n        const bonusBall = createBall(draw.bonus, true, false)\n        ballsEl.appendChild(bonusBall)\n\n        requestAnimationFrame(() => {\n          setTimeout(() => plus.classList.add('show'), draw.main.length * 70)\n          setTimeout(\n            () => bonusBall.classList.add('show'),\n            draw.main.length * 70 + 120,\n          )\n        })\n      }\n\n      function renderHistory() {\n        historyListEl.innerHTML = ''\n\n        if (!history.length) {\n          historyListEl.innerHTML =\n            '<div class=\"empty\">아직 추첨 기록이 없습니다.</div>'\n          return\n        }\n\n        history.forEach((item, index) => {\n          const wrap = document.createElement('div')\n          wrap.className = 'history-item'\n\n          const head = document.createElement('div')\n          head.className = 'history-head'\n          head.innerHTML = `<span>${index + 1}번째 추첨</span><span>${item.time}</span>`\n\n          const mini = document.createElement('div')\n          mini.className = 'mini-balls'\n          item.main.forEach((num) =>\n            mini.appendChild(createBall(num, false, true)),\n          )\n\n          const plus = document.createElement('span')\n          plus.textContent = '+'\n          plus.style.opacity = '0.8'\n          plus.style.fontWeight = '800'\n          plus.style.margin = '0 2px'\n          mini.appendChild(plus)\n          mini.appendChild(createBall(item.bonus, true, true))\n\n          wrap.appendChild(head)\n          wrap.appendChild(mini)\n          historyListEl.appendChild(wrap)\n        })\n      }\n\n      function renderStats() {\n        totalDrawsEl.textContent = `${history.length}회`\n        if (latestDraw) {\n          latestSummaryEl.textContent = `${latestDraw.main.join('-')} + ${latestDraw.bonus}`\n          roundLabelEl.textContent = `최근 추첨 ${history.length}회차`\n        } else {\n          latestSummaryEl.textContent = '-'\n          roundLabelEl.textContent = '준비 완료'\n        }\n      }\n\n      function nowString() {\n        const now = new Date()\n        const y = now.getFullYear()\n        const m = String(now.getMonth() + 1).padStart(2, '0')\n        const d = String(now.getDate()).padStart(2, '0')\n        const hh = String(now.getHours()).padStart(2, '0')\n        const mm = String(now.getMinutes()).padStart(2, '0')\n        const ss = String(now.getSeconds()).padStart(2, '0')\n        return `${y}.${m}.${d} ${hh}:${mm}:${ss}`\n      }\n\n      async function animatedDraw() {\n        if (drawing) return\n        drawing = true\n        drawBtn.disabled = true\n        quickBtn.disabled = true\n        statusEl.textContent = '번호를 추첨하는 중입니다...'\n        ballsEl.innerHTML = ''\n\n        const finalPick = pickNumbers()\n        const previewCycles = 10\n\n        for (let i = 0; i < previewCycles; i++) {\n          const temp = pickNumbers()\n          renderCurrent(temp)\n          await wait(110)\n        }\n\n        ballsEl.innerHTML = ''\n        for (let i = 0; i < finalPick.main.length; i++) {\n          const ball = createBall(finalPick.main[i])\n          ballsEl.appendChild(ball)\n          requestAnimationFrame(() => ball.classList.add('show'))\n          statusEl.textContent = `${i + 1}번째 번호 공개 중...`\n          await wait(380)\n        }\n\n        const plus = document.createElement('div')\n        plus.className = 'plus show'\n        plus.textContent = '+'\n        ballsEl.appendChild(plus)\n        await wait(220)\n\n        const bonusBall = createBall(finalPick.bonus, true)\n        ballsEl.appendChild(bonusBall)\n        requestAnimationFrame(() => bonusBall.classList.add('show'))\n        await wait(240)\n\n        finalizeDraw(finalPick)\n      }\n\n      function instantDraw() {\n        if (drawing) return\n        const draw = pickNumbers()\n        renderCurrent(draw)\n        finalizeDraw(draw)\n      }\n\n      function finalizeDraw(draw) {\n        latestDraw = { ...draw, time: nowString() }\n        history.unshift(latestDraw)\n        history = history.slice(0, 20)\n        saveHistory()\n        renderHistory()\n        renderStats()\n        statusEl.textContent = `추첨 완료! 번호: ${draw.main.join(', ')} + 보너스 ${draw.bonus}`\n        drawing = false\n        drawBtn.disabled = false\n        quickBtn.disabled = false\n      }\n\n      function wait(ms) {\n        return new Promise((resolve) => setTimeout(resolve, ms))\n      }\n\n      async function copyLatest() {\n        if (!latestDraw) {\n          statusEl.textContent = '복사할 추첨 번호가 없습니다.'\n          return\n        }\n        const text = `로또 번호: ${latestDraw.main.join(', ')} + 보너스 ${latestDraw.bonus}`\n        try {\n          await navigator.clipboard.writeText(text)\n          statusEl.textContent = '최근 추첨 번호를 클립보드에 복사했습니다.'\n        } catch {\n          statusEl.textContent =\n            '복사에 실패했습니다. 브라우저 권한을 확인해주세요.'\n        }\n      }\n\n      function resetHistory() {\n        const ok = confirm('저장된 추첨 기록을 모두 삭제할까요?')\n        if (!ok) return\n        history = []\n        latestDraw = null\n        saveHistory()\n        ballsEl.innerHTML = ''\n        renderHistory()\n        renderStats()\n        statusEl.textContent = '추첨 기록이 초기화되었습니다.'\n      }\n\n      drawBtn.addEventListener('click', animatedDraw)\n      quickBtn.addEventListener('click', instantDraw)\n      copyBtn.addEventListener('click', copyLatest)\n      resetBtn.addEventListener('click', resetHistory)\n\n      renderHistory()\n      renderStats()\n      if (latestDraw) renderCurrent(latestDraw)\n    </script>\n  </body>\n</html>\n"
        }
    ]
}